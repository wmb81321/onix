# Tempo — Virtual Address Master
AGENT_MASTER_ADDRESS=      # EVM address of agent EOA (access key wallet)
AGENT_MASTER_ID=           # from VirtualMaster.mineSaltAsync() — NEVER lose this
AGENT_MASTER_SALT=         # PoW salt from mining — NEVER lose this
AGENT_ACCESS_KEY=          # EOA private key (0x-prefixed 32 bytes)
AGENT_ACCESS_KEY_ADDRESS=  # EVM address matching AGENT_ACCESS_KEY

# Tempo — Chain
TEMPO_RPC_URL=https://rpc.tempo.xyz
TEMPO_TESTNET_RPC_URL=https://rpc.moderato.tempo.xyz   # required for testnet/Moderato
TEMPO_CHAIN_ID=42431                                   # 42431 = Moderato testnet
TEMPO_PATHUSDC_ADDRESS=0x20c0000000000000000000000000000000000000

# Tempo — MPP session server (agent only)
CHARGE_AMOUNT_USDC=0.1
FACILITATOR_URL=           # public URL of this agent, e.g. https://your-agent.railway.app
MPP_SECRET_KEY=            # min 16 chars — HMAC-binds challenge IDs (keep secret)

# Stripe (agent + frontend)
STRIPE_SECRET_KEY=sk_...
STRIPE_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
STRIPE_WEBHOOK_SECRET=whsec_...   # from Stripe dashboard (live) or `stripe listen` (test)

# Supabase
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # agent only — NEVER expose to browser
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # browser-safe anon key

# Agent runtime
AGENT_PORT=3001
NODE_ENV=development   # set to production on Railway
