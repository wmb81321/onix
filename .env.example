# Tempo — Virtual Address Master
AGENT_MASTER_ADDRESS=      # EVM address of agent's master wallet (used for mining)
AGENT_MASTER_ID=           # from VirtualMaster.mineSaltAsync() — store and never lose
AGENT_ACCESS_KEY=          # scoped signing key with spending cap (private key hex)
TEMPO_RPC_URL=https://rpc.tempo.xyz
TEMPO_TESTNET_RPC_URL=https://testnet-rpc.tempo.xyz
NEXT_PUBLIC_TEMPO_RPC_URL=https://rpc.tempo.xyz

# Tempo — MPP session server
MPP_SERVICE_PORT=3001
CHARGE_AMOUNT_USDC=0.1
FACILITATOR_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Agent
AGENT_PORT=3001
LOG_LEVEL=info
NODE_ENV=development
